# ==========================================
# ENVIRONMENT CONFIGURATION — CRM Hotelero
# ==========================================
# Copia este archivo como .env y rellena tus datos
# NUNCA subas .env a GitHub

# --- Servidor ---
NODE_ENV=production
PORT=3000

# --- Google Cloud ---
# Obtener de: https://console.cloud.google.com/apis/credentials
GOOGLE_PROJECT_ID=tu_project_id_aqui
GOOGLE_CLIENT_ID=tu_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:8080
GOOGLE_SPREADSHEET_ID=id_hoja_calculo
GOOGLE_CREDENTIALS_FILE=credentials.json

# --- Google Sheets (opcional - para CMS) ---
CRM_SHEETS_SPREADSHEET_ID=id_hoja_cms

# --- WhatsApp Business API ---
# Obtener de: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=id_telefono_comercial
WHATSAPP_TOKEN=tu_token_whatsapp
WHATSAPP_VERIFY_TOKEN=frase_secreta_webhook

# --- Instagram Graph API ---
INSTAGRAM_BUSINESS_ACCOUNT_ID=id_cuenta_comercial
INSTAGRAM_ACCESS_TOKEN=tu_token_instagram

# --- Telegram Bot (opcional) ---
TELEGRAM_BOT_TOKEN=tu_token_bot
TELEGRAM_CHAT_ID=id_chat_grupo

# --- GitHub (para deploy automático) ---
GITHUB_TOKEN=tu_personal_access_token
GITHUB_REPO=usuario/repo

# --- Gmail (opcional - para notificaciones) ---
GMAIL_USER=tu_email@gmail.com
GMAIL_APP_PASSWORD=tu_password_aplicacion
